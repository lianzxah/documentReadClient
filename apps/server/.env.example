# Backend
PORT=8787
HOST=127.0.0.1

# ----------------------------------------------------------------------------
# Model providers (OPTIONAL)
#
# These keys are now FALLBACK defaults only. The in-app Settings dialog
# (gear icon in the activity bar) writes its values to
# `apps/server/.data/settings.json`, which overrides anything here.
# Resolution order per field: settings.json > .env > built-in default.
#
# Leave the *_API_KEY values empty to force the user to configure them via
# the Settings UI on first run.
# ----------------------------------------------------------------------------

# DeepSeek (default chat LLM, OpenAI-compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Qwen embeddings via Aliyun DashScope (OpenAI-compatible)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_EMBED_MODEL=text-embedding-v3

# Storage
LANCEDB_PATH=./.data/lancedb
DATA_DIR=./.data

# Limits
MAX_PDF_MB=50
FETCH_TIMEOUT_MS=60000
