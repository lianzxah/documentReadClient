{
  "name": "@app/electron",
  "version": "1.0.0",
  "description": "Document Reader - Electron desktop client",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "build": {
    "appId": "com.document.reader",
    "productName": "Document Reader",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../server/dist",
        "to": "server",
        "filter": ["**/*"]
      },
      {
        "from": "../server/package.json",
        "to": "server/package.json"
      },
      {
        "from": "../server/node_modules",
        "to": "server/node_modules",
        "filter": ["**/*"]
      },
      {
        "from": "../web/dist",
        "to": "web/dist",
        "filter": ["**/*"]
      }
    ],
    "asarUnpack": [
      "**/node_modules/@lancedb/lancedb/**/*",
      "**/node_modules/puppeteer/**/*"
    ],
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "get-port": "^7.2.0"
  }
}
